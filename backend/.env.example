# TradeMentor-AI Environment Variables
# Скопируй этот файл в .env и заполни реальными значениями

# ── Database (Supabase) ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.XXXXXX:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your_random_secret_min_32_chars"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── AI API Keys ───────────────────────────────────────────────────────────────
OPENROUTER_KEY_1="sk-or-v1-..."
OPENROUTER_KEY_2="sk-or-v1-..."
SAMBANOVA_KEY="your-sambanova-key"
HYPERBOLIQ_KEY="sk_live_..."
